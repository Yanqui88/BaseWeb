DATABASE_URL=postgresql://user:password@localhost:5432/dbname?schema=public
PORT=4000
JWT_SECRET=your-super-secret-at-least-32-chars

# Redis (caché distribuida) — Fase 3 Hito 7
REDIS_URL=redis://localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Mercado Pago OAuth
MP_CLIENT_ID=YOUR_MP_CLIENT_ID
MP_CLIENT_SECRET=YOUR_MP_CLIENT_SECRET
MP_ENCRYPTION_KEY=64-hex-chars-encryption-key

# Mercado Pago Webhook HMAC Secret (Hito 8 – Seguridad y Auditoría)
# Obtener desde: Panel MP → Integraciones → Webhooks → tu app → Secret
MP_WEBHOOK_SECRET=your-mp-webhook-hmac-secret

# Métricas internas (Fase X — Hito métricas)
# Protege los endpoints GET /metrics/health y GET /metrics/stats
ADMIN_API_KEY=secreto_super_seguro