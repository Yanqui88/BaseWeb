DATABASE_URL=postgresql://user:password@localhost:5432/dbname?schema=public
PORT=4000
JWT_SECRET=your-super-secret-at-least-32-chars

# Redis (caché distribuida) — Fase 3 Hito 7
REDIS_URL=redis://localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Mercado Pago OAuth
MP_CLIENT_ID=YOUR_MP_CLIENT_ID
MP_CLIENT_SECRET=YOUR_MP_CLIENT_SECRET
MP_ENCRYPTION_KEY=64-hex-chars-encryption-key

# Mercado Pago Webhook HMAC Secret (Hito 8 – Seguridad y Auditoría)
# Obtener desde: Panel MP → Integraciones → Webhooks → tu app → Secret
MP_WEBHOOK_SECRET=your-mp-webhook-hmac-secret

# Métricas internas (Fase X — Hito métricas)
# Protege los endpoints GET /metrics/health y GET /metrics/stats
ADMIN_API_KEY=secreto_super_seguro

# ── Hito 8 Fase 5 — Caddy ↔ NestJS Proxy Guard ─────────────────────────────
# Secret compartido entre Caddy y la API para autenticar peticiones internas.
# Generar con: openssl rand -hex 32
# Configurar también en Caddyfile como header X-Proxy-Secret.
CADDY_PROXY_SECRET=your-caddy-proxy-secret-min-32-chars

# ── Backups PostgreSQL → S3 ─────────────────────────────────────────────────
# Bucket donde se almacenan los backups (.sql.gz)
BACKUP_S3_BUCKET=proyectoweb-backups
# Endpoint S3-compatible: Cloudflare R2, MinIO, etc. (vacío = AWS S3 nativo)
BACKUP_S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# Región del bucket: "auto" para R2, "us-east-1" para AWS
BACKUP_S3_REGION=auto
# Días de retención de backups (0 = sin limpieza automática)
BACKUP_RETENTION_DAYS=30
# Prefijo de ruta dentro del bucket
BACKUP_PREFIX=db-backups
# AWS CLI credentials (usar IAM / R2 API Token con permisos mínimos)
AWS_ACCESS_KEY_ID=your-s3-access-key
AWS_SECRET_ACCESS_KEY=your-s3-secret-key