# =============================================================================
# .env.production — Variables de entorno para producción Docker
# Copia este archivo como .env.production y rellena con valores reales.
# NUNCA subas este archivo al repositorio (ya está en .gitignore).
# =============================================================================

# ----------------------------------------------------------------------------
# PostgreSQL
# ----------------------------------------------------------------------------
POSTGRES_USER=proyectoweb
POSTGRES_PASSWORD=CAMBIA_ESTA_PASSWORD_SEGURA
POSTGRES_DB=proyectoweb_prod

# La URL completa es construida automáticamente por docker-compose.yml
# usando el nombre de servicio 'postgres' como host interno.
# DATABASE_URL se inyecta directamente en el servicio 'api'.

# ----------------------------------------------------------------------------
# JWT / Seguridad
# ----------------------------------------------------------------------------
JWT_SECRET=CAMBIA_ESTE_SECRET_DE_AL_MENOS_64_CARACTERES_ALEATORIOS

# ----------------------------------------------------------------------------
# Mercado Pago
# ----------------------------------------------------------------------------
MP_CLIENT_ID=TU_MP_CLIENT_ID
MP_CLIENT_SECRET=TU_MP_CLIENT_SECRET
MP_ENCRYPTION_KEY=64_CHARS_HEX_KEY_PARA_CIFRADO_DE_TOKENS
MP_WEBHOOK_SECRET=TU_MP_WEBHOOK_HMAC_SECRET

# ----------------------------------------------------------------------------
# Clave de API interna para endpoints protegidos (/metrics, /admin)
# ----------------------------------------------------------------------------
ADMIN_API_KEY=CAMBIA_ESTE_KEY_SECRETO

# ----------------------------------------------------------------------------
# URLs públicas (usadas por Next.js en el lado cliente, NEXT_PUBLIC_*)
# Pon el dominio real o IP del VPS
# ----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=https://api.tudominio.com

# ----------------------------------------------------------------------------
# Caddy — Proxy Inverso
# ----------------------------------------------------------------------------
# Secret compartido entre Caddy y NestJS.
# Caddy lo inyecta en cada request interno como header 'X-Proxy-Secret'.
# NestJS puede usarlo en un Guard para aceptar SOLO requests que vengan
# del proxy de confianza (útil para rutas internas o rate-limiting).
# Genera con: openssl rand -hex 32
CADDY_PROXY_SECRET=GENERA_UN_SECRET_HEX_DE_64_CHARS

# Email de contacto para Let's Encrypt (se configura en el Caddyfile).
# Cambia 'admin@tudominio.com' en el Caddyfile con este valor.
CADDY_ACME_EMAIL=admin@tudominio.com

# Dominio raíz de la plataforma SaaS multi-tenant.
# NestJS lo usa en TenantsService para extraer el slug de subdominios dinámicos.
# Ejemplo: si ROOT_DOMAIN=tuplataforma.com, una petición a "mitienda.tuplataforma.com"
#          busca en la BD el tenant con domain='mitienda'.
# En desarrollo local con localhost, puedes dejarlo vacío (el FQDN completo se usará como slug).
ROOT_DOMAIN=tuplataforma.com

# ----------------------------------------------------------------------------
# Opcional: configuración de correo (si se añade en el futuro)
# ----------------------------------------------------------------------------
# SMTP_HOST=smtp.tudominio.com
# SMTP_PORT=587
# SMTP_USER=noreply@tudominio.com
# SMTP_PASS=password_smtp
